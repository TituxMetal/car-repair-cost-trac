// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vehicle {
  id            String   @id @default(cuid())
  make          String
  model         String
  year          Int
  vin           String?
  licensePlate  String?
  purchaseDate  String?
  currentOdometer Int
  fuelType      String?
  engineType    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  maintenanceEvents MaintenanceEvent[]
  expenses          Expense[]
  budget            Budget?
  reminders         RecurringReminder[]
}

model MaintenanceEvent {
  id               String   @id @default(cuid())
  vehicleId        String
  category         String
  type             String
  title            String
  description      String?
  scheduledDate    String?
  scheduledMileage Int?
  completedDate    String?
  completedMileage Int?
  status           String   @default("scheduled")
  appointmentTime  String?
  appointmentPlace String?
  appointmentReason String?
  
  // Recurring check fields
  isRecurring       Boolean  @default(false)
  recurrenceType    String?  // 'weekly', 'monthly', 'mileage'
  recurrenceValue   Int?     // 1 = every week/month, 5000 = every 5000km
  parentEventId     String?  // Links to the original recurring check
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expenses Expense[]
}

model Expense {
  id          String   @id @default(cuid())
  eventId     String?
  vehicleId   String
  date        String
  garageName  String?
  description String?
  partsCost   Float    @default(0)
  laborCost   Float    @default(0)
  otherCost   Float    @default(0)
  totalCost   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  event   MaintenanceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Budget {
  id        String   @id @default(cuid())
  vehicleId String   @unique
  amount    Float
  period    String   @default("monthly")
  startDate String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model RecurringReminder {
  id                   String   @id @default(cuid())
  vehicleId            String
  category             String
  title                String
  description          String?
  recurrenceType       String   // 'time', 'mileage', 'both'
  mileageInterval      Int?     // e.g., 5000 (km)
  timeInterval         Int?     // e.g., 3
  timeUnit             String?  // 'days', 'weeks', 'months', 'years'
  lastCompletedDate    String?
  lastCompletedMileage Int?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
